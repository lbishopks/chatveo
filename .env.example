# Copy to .env for local use, or set these in your host's dashboard (Render, etc.).
# Never commit real secrets — .env is gitignored.

# Admin dashboard login (/admin). CHANGE THE PASSWORD before deploying.
ADMIN_USER=admin
ADMIN_PASSWORD=change-this-to-something-strong

# Where the SQLite DB + data live. On a host, point this at a persistent disk.
# DATA_DIR=/data

# Stripe (leave unset to run Premium in DEMO mode).
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...        # from the Stripe webhook you create
# PREMIUM_PRICE_ID=price_...             # optional; else a $9.99/mo price is built inline
# PREMIUM_AMOUNT=999                     # cents, if not using a price id

# TURN server (makes mobile connections reliable). Get free creds from Metered, etc.
# TURN_URL=turn:your.turn.host:3478      # comma-separate multiple URLs if given
# TURN_USER=your-turn-username
# TURN_PASS=your-turn-credential

# Chat retention cap (number of sessions kept).
# CHAT_RETENTION_MAX=2000
